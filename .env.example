# Database
POSTGRES_USER=macro
POSTGRES_PASSWORD=macro_secret
POSTGRES_DB=macrodb
DATABASE_URL=postgresql+asyncpg://macro:macro_secret@timescaledb:5432/macrodb
DATABASE_URL_SYNC=postgresql://macro:macro_secret@timescaledb:5432/macrodb

# Redis
REDIS_URL=redis://redis:6379/0

# API Keys (free tiers)
FRED_API_KEY=your_fred_api_key_here        # https://fred.stlouisfed.org/docs/api/api_key.html
ALPHA_VANTAGE_KEY=your_alpha_vantage_key   # https://www.alphavantage.co/support/#api-key
GNEWS_API_KEY=                             # Optional: https://gnews.io (free 100/day) — leave blank for RSS fallback

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# App
APP_ENV=development
APP_SECRET_KEY=change_this_in_production
CORS_ORIGINS=http://localhost:3000
