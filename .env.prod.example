# ── Production Environment ────────────────────────────────────────────────────
# Copy to .env on your VPS and fill in all values.
# NEVER commit .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=your@email.com

# ── Database (TimescaleDB) ────────────────────────────────────────────────────
POSTGRES_USER=macro
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=macrodb
DATABASE_URL=postgresql+asyncpg://macro:CHANGE_THIS_STRONG_PASSWORD@timescaledb:5432/macrodb
DATABASE_URL_SYNC=postgresql://macro:CHANGE_THIS_STRONG_PASSWORD@timescaledb:5432/macrodb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_SECRET_KEY=CHANGE_THIS_SECRET_64_CHARS_RANDOM_STRING
CORS_ORIGINS=https://yourdomain.com

# ── API Keys ──────────────────────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_KEY=
GNEWS_API_KEY=
